DB_PATH = Path(__file__).resolve().parent.parent / "database" / "racing.db"

HEADERS = {
    "User-Agent": "Mozilla/5.0",
    "Accept": "application/json",
    "Origin": "https://www.racing.com",
    "Referer": "https://www.racing.com/",
